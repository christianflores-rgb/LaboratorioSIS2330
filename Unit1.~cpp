void dda(int xIni,int xFin,int yIni,int yFin){
    float pendiente = (yFin-yIni)/(xFin-xIni)   ;
    int dx = abs(xFin-xIni);
    int dy =  abs(yFin-yIni);
    int pasos = (dx>dy) ? dx:dy;
    float x = xIni;
    float y = yIni;
    float incX = dx/pasos;
    float incY = dy/pasos;
    for(int i=0;i<pasos;i++)
    {
     if(pendiente<=1){
       x=x+1.0 ;
       y=y+(1.0/pendiente);
     }
     else{
      y=y+1.0;
      x=x+(1.0/pendiente);
     }
     Form1->Canvas->Pixels[(int)x][(int)y] = clBlack;
         x=x+incX;
         y=y+incX;
    }

